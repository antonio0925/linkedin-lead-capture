# ──────────────────────────────────────────────────────────────
# LinkedIn Lead Capture — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in YOUR values.
# These values are entered in the extension popup, not loaded
# from this file at runtime. This file exists as a reference
# for what you'll need to configure.
# ──────────────────────────────────────────────────────────────

# Your personal n8n webhook URL.
# IMPORTANT: Each team member MUST use their own webhook URL
# so that activity is logged under their own accounts.
# See README.md for instructions on setting up your n8n workflow.
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/your-unique-id

# Optional: HubSpot API key (used by n8n, not the extension directly)
HUBSPOT_API_KEY=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Your HubSpot owner ID (for assigning contacts to yourself)
HUBSPOT_OWNER_ID=123456789
